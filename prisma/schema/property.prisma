model Property {
    id           String   @id @default(uuid())
    landlordId   String
    categoryId   String
    title        String   @db.VarChar(255)
    description  String   @db.Text
    rent         Decimal  @db.Decimal(10, 2) // usd
    bedrooms     Int?
    bathrooms    Int?
    area         Decimal? @db.Decimal(8, 2) //sqrft
    gMapLocation String?  @db.Text
    address      String   @db.Text
    city         String   @db.VarChar(255)
    division     String   @db.VarChar(255)
    country      String   @db.VarChar(255)

    status                     PropertyStatus   @default(AVAILABLE)
    rentalType                 RentalType       @default(MONTHLY)
    availableRentalPeriodMonth Int?             @default(1)
    rentalRequest              Rental_Request[]

    isDeleted Boolean   @default(false)
    deletedAt DateTime?
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt

    landlord User     @relation(fields: [landlordId], references: [id], onDelete: Cascade)
    category Category @relation(fields: [categoryId], references: [id])

    @@unique([landlordId, title, address], name: "unique_landlord_property")
    @@index([landlordId])
    @@index([categoryId])
    @@index([landlordId, status])
    @@map("Properties")
}
